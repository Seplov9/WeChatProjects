<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索需求..." value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="onSearch" />
  </view>

  <view class="filter-area">
    <view class="filter-row">
      <view class="filter-cell filter-online">
        <picker mode="selector" range="{{onlineOptions}}" bindchange="onOnlineChange">
          <view class="filter-text">{{onlineOptions[onlineIndex]}} ▾</view>
        </picker>
      </view>
      <view class="filter-cell filter-category">
        <picker mode="selector" range="{{categoryOptions}}" bindchange="onCategoryChange">
          <view class="filter-text">{{categoryOptions[categoryIndex]}} ▾</view>
        </picker>
      </view>
    </view>
    <view class="filter-row">
      <view class="filter-cell filter-province">
        <picker mode="selector" range="{{provinceOptions}}" bindchange="onProvinceChange">
          <view class="filter-text">{{provinceOptions[provinceIndex]}} ▾</view>
        </picker>
      </view>
      <view class="filter-cell filter-city-l2">
        <picker mode="selector" range="{{cityOptions}}" bindchange="onCityChange">
          <view class="filter-text">{{cityOptions[cityIndex]}} ▾</view>
        </picker>
      </view>
      <view class="filter-cell filter-district">
        <picker mode="selector" range="{{districtOptions}}" bindchange="onDistrictChange">
          <view class="filter-text">{{districtOptions[districtIndex]}} ▾</view>
        </picker>
      </view>
    </view>
  </view>

  <view class="order-list">
    <view class="card" wx:for="{{filteredOrders}}" wx:key="_id" bindtap="onCardTap" data-index="{{index}}">
      <image wx:if="{{item.images && item.images.length > 0}}" class="card-image" src="{{item.images[0]}}" mode="aspectFill" />
      <view class="card-top">
        <text class="card-category">{{item.category}}</text>
        <view class="card-top-right">
          <text class="card-reward">¥{{item.reward}}</text>
          <view class="fav-btn" catchtap="onToggleFav" data-index="{{index}}">
            <text class="fav-star {{item.isFaved ? 'faved' : ''}}">{{item.isFaved ? '★' : '☆'}}</text>
          </view>
        </view>
      </view>
      <view class="card-title">{{item.title}}</view>
      <view class="card-content">{{item.content}}</view>
      <view class="card-bottom">
        <text class="card-city" wx:if="{{item.city}}">{{item.city}}</text>
        <text class="card-time">{{item.createdAt}}</text>
      </view>
    </view>
    <view wx:if="{{filteredOrders.length === 0}}" class="empty">暂无需求</view>

    <view class="load-more" wx:if="{{filteredOrders.length > 0}}">
      <view wx:if="{{loadingMore}}" class="load-more-text">加载中...</view>
      <view wx:elif="{{hasMore}}" class="load-more-text">上拉加载更多</view>
      <view wx:else class="load-more-text load-more-end">— 已加载全部 —</view>
    </view>
  </view>
</view>
