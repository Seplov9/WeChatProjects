.page {
  padding: 32rpx 30rpx;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom) + 40rpx);
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.header-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999;
}

/* 分区 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #999;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

/* 两行下拉 */
.filter-area {
  width: 100%;
}

.filter-row {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-cell {
  flex-shrink: 0;
  margin-right: 12rpx;
}

.filter-cell:last-child {
  margin-right: 0;
}

.filter-online {
  width: 110rpx;
}

.filter-category {
  width: 200rpx;
}

.filter-province {
  width: 160rpx;
}

.filter-city-l2 {
  width: 160rpx;
}

.filter-district {
  width: 160rpx;
}

.filter-text {
  height: 60rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 表单字段 */
.field {
  position: relative;
  margin-bottom: 20rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-textarea {
  margin-bottom: 0;
}

.field-input {
  width: 100%;
  height: 80rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.field-input-num {
  padding-left: 48rpx;
}

.field-prefix {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 30rpx;
  font-weight: 600;
  color: #ee3f4d;
  z-index: 1;
}

.field-textarea {
  width: 100%;
  height: 200rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.field-count {
  position: absolute;
  right: 20rpx;
  bottom: -28rpx;
  font-size: 22rpx;
  color: #bbb;
}

.area-count {
  bottom: 10rpx;
}

/* 双列 */
.field-row {
  display: flex;
  gap: 20rpx;
}

.field-half {
  flex: 1;
  margin-bottom: 0;
}

/* 提交区 */
.submit-area {
  margin-top: 40rpx;
  text-align: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.submit-hint {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #bbb;
}

.btn-row {
  display: flex;
  gap: 20rpx;
}

.submit-btn-half {
  flex: 1;
}

.cancel-btn {
  flex: 1;
  height: 96rpx;
  background: #fff;
  color: #ee3f4d;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 2rpx solid #ee3f4d;
}

/* 图片上传 */
.section-optional {
  font-size: 24rpx;
  color: #bbb;
  font-weight: 400;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 144rpx;
  height: 144rpx;
  border-radius: 10rpx;
  position: relative;
  overflow: hidden;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 10rpx 0 10rpx;
}

.image-add {
  background: #f7f8fa;
  border: 2rpx dashed #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.image-add-icon {
  font-size: 56rpx;
  color: #ccc;
}
