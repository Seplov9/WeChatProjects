<view class="page">
  <view class="header">
    <view class="header-icon">📋</view>
    <view class="header-title">发布需求</view>
    <view class="header-desc">填写以下信息，让接单者快速了解你的需求</view>
  </view>

  <view class="section">
    <view class="section-title">需求分类</view>
    <view class="filter-area">
      <view class="filter-row">
        <view class="filter-cell filter-online">
          <picker mode="selector" range="{{onlineOptions}}" bindchange="onOnlineChange">
            <view class="filter-text">{{onlineOptions[onlineIndex]}} ▾</view>
          </picker>
        </view>
        <view class="filter-cell filter-category">
          <picker mode="selector" range="{{categoryOptions}}" bindchange="onCategoryChange">
            <view class="filter-text">{{categoryOptions[categoryIndex]}} ▾</view>
          </picker>
        </view>
      </view>
      <view class="filter-row">
        <view class="filter-cell filter-province">
          <picker mode="selector" range="{{provinceOptions}}" bindchange="onProvinceChange">
            <view class="filter-text">{{provinceOptions[provinceIndex]}} ▾</view>
          </picker>
        </view>
        <view class="filter-cell filter-city-l2">
          <picker mode="selector" range="{{cityOptions}}" bindchange="onCityChange">
            <view class="filter-text">{{cityOptions[cityIndex]}} ▾</view>
          </picker>
        </view>
        <view class="filter-cell filter-district">
          <picker mode="selector" range="{{districtOptions}}" bindchange="onDistrictChange">
            <view class="filter-text">{{districtOptions[districtIndex]}} ▾</view>
          </picker>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">需求图片 <text class="section-optional">(选填)</text></view>
    <view class="image-grid">
      <view class="image-item" wx:for="{{images}}" wx:key="index">
        <image class="image-thumb" src="{{item}}" mode="aspectFill" />
        <view class="image-del" catchtap="onDelImage" data-index="{{index}}">✕</view>
      </view>
      <view class="image-item image-add" bindtap="onChooseImage" wx:if="{{images.length < 9}}">
        <text class="image-add-icon">+</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">需求详情</view>
    <view class="field">
      <input
        class="field-input"
        placeholder="给你的需求起个标题"
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="50"
      />
      <view class="field-count">{{title.length}}/50</view>
    </view>
    <view class="field field-textarea">
      <textarea
        class="field-textarea"
        placeholder="详细描述你的需求内容、具体要求等"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="500"
      />
      <view class="field-count area-count">{{content.length}}/500</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">报酬与联系</view>
    <view class="field-row">
      <view class="field field-half">
        <view class="field-prefix">¥</view>
        <input
          class="field-input field-input-num"
          type="digit"
          placeholder="薪酬"
          value="{{reward}}"
          bindinput="onRewardInput"
        />
      </view>
      <view class="field field-half">
        <input
          class="field-input"
          placeholder="微信/电话"
          value="{{contact}}"
          bindinput="onContactInput"
          maxlength="50"
        />
      </view>
    </view>
  </view>

  <view class="submit-area">
    <view class="btn-row" wx:if="{{editId}}">
      <button class="submit-btn submit-btn-half" bindtap="submitOrder">保存修改</button>
      <button class="cancel-btn submit-btn-half" bindtap="cancelOrder">撤销发布</button>
    </view>
    <button class="submit-btn" wx:else bindtap="submitOrder">立即发布</button>
    <view class="submit-hint" wx:if="{{!editId}}">发布后需求将进入信息池，所有会员可见</view>
  </view>
</view>
