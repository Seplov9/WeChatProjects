.page {
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom) + 40rpx);
}

/* 图片轮播 */
.image-area {
  width: 100%;
}

.image-swiper {
  width: 100%;
  height: 500rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 详情卡片 */
.detail-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.detail-category-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.detail-category {
  font-size: 22rpx;
  color: #07c160;
  background: #e8f8ee;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.detail-reward {
  font-size: 40rpx;
  font-weight: 700;
  color: #ee3f4d;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.detail-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

.detail-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 28rpx 0;
}

/* 发布者 */
.detail-publisher {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.detail-publisher:active {
  opacity: 0.6;
}

.publisher-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.publisher-avatar-empty {
  background: #e0e0e0;
}

.publisher-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.publisher-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* 信息行 */
.detail-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.detail-info-row + .detail-info-row {
  border-top: 1rpx solid #f5f5f5;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
}
