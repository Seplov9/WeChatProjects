.page {
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom) + 40rpx);
}

/* 发布者头部 */
.publisher-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 40rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.header-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.header-avatar-empty {
  background: #e0e0e0;
}

.header-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.header-count {
  font-size: 24rpx;
  color: #999;
}

/* 卡片列表（复用需求池样式） */
.card {
  background: #fff;
  padding: 28rpx 24rpx;
  margin-bottom: 4rpx;
}

.card-image {
  width: 100%;
  height: 280rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-category {
  font-size: 22rpx;
  color: #07c160;
  background: #e8f8ee;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.card-reward {
  font-size: 36rpx;
  font-weight: 700;
  color: #ee3f4d;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.card-content {
  font-size: 26rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #999;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding-top: 120rpx;
}
