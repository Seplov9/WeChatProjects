.container {
  padding: 20rpx 0;
  padding-bottom: 40rpx;
  align-items: stretch;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 16rpx;
  padding: 0 24rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 筛选行 */
.filter-area {
  margin-bottom: 24rpx;
  padding: 0 24rpx;
}

.filter-row {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-cell {
  flex-shrink: 0;
  margin-right: 12rpx;
}

.filter-cell:last-child {
  margin-right: 0;
}

.filter-online {
  width: 110rpx;
}

.filter-category {
  width: 200rpx;
}

.filter-province {
  width: 160rpx;
}

.filter-city-l2 {
  width: 160rpx;
}

.filter-district {
  width: 160rpx;
}

.filter-text {
  height: 60rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 0;
  padding: 28rpx 24rpx;
  margin-bottom: 4rpx;
}

.card-image {
  width: 100%;
  height: 280rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-category {
  font-size: 22rpx;
  color: #07c160;
  background: #e8f8ee;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.card-reward {
  font-size: 36rpx;
  font-weight: 700;
  color: #ee3f4d;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.card-content {
  font-size: 26rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-city {
  font-size: 22rpx;
  color: #999;
}

.card-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.tag-active {
  color: #07c160;
  background: #e8f8ee;
}

.tag-closed {
  color: #999;
  background: #f0f0f0;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding-top: 120rpx;
}
